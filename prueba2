import discord 
from discord.ext import commands

intents = discord.Intents.default()
intents.message_content = True

bot = commands.Bot(command_prefix="!", intents=intents)
TOKEN = "Tu_Token"

@bot.event
async def on_ready():
    print(f"Se ha iniciado como {bot.user}")
@bot.command()
async def calcular(ctx, num1: float,simbolo: str, num2: float):
    if simbolo == "+":
        resultado = num1 + num2
    elif simbolo == "-":
        resultado = num1 - num2
    else:
        resultado = "Escribe un número ya sea entero o decimal"
    await ctx.send(f"El resultado es: {resultado}")

@bot.command()
async def hola(ctx):
    await ctx.send("Oh, hola que tal, ¿Como estás?")

bot.run(TOKEN)
