import discord 
from discord.ext import commands
import os
import random

intents = discord.Intents.default()
intents.message_content = True

bot = commands.Bot(command_prefix="!", intents=intents)
TOKEN = "Tu token"

@bot.event
async def on_ready():
    print(f"Se ha iniciado como {bot.user}")
@bot.command()
async def calcular(ctx, num1: float,simbolo: str, num2: float):
    if simbolo == "+":
        resultado = num1 + num2
    elif simbolo == "-":
        resultado = num1 - num2
    else:
        resultado = "Escribe un número ya sea entero o decimal"
    await ctx.send(f"El resultado es: {resultado}")

@bot.command()
async def imágenes(ctx):
    li = os.listdir("img")
    rndm = random.choice(li)
    with open(f"img/{rndm}","br") as img:
        leer = img.read()
        ruta = os.path.join("img", rndm)
        pinturaamostrar = discord.File(ruta)
        await ctx.send(file=pinturaamostrar)

@bot.command()
async def comandos(ctx):
    await ctx.send("Los comandos son: !imágenes, !hola, !calcular x +/- y(donde x i y son números)")

